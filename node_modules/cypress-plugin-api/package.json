{
  "author": "Filip Hric (https://filiphric.com/)",
  "license": "ISC",
  "name": "cypress-plugin-api",
  "version": "2.12.0",
  "type": "module",
  "keywords": [
    "cypress",
    "api",
    "testing",
    "plugin"
  ],
  "description": "UI for testing API in Cypress",
  "main": "dist/support.cjs",
  "types": "dist/types.d.ts",
  "files": [
    "/dist/*"
  ],
  "scripts": {
    "test": "cypress run",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "start": "node ./server",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "lint": "tsc --noEmit && eslint . --max-warnings=15 --quiet",
    "semantic-release": "semantic-release",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "release:major": "standard-version --release-as major"
  },
  "pre-commit": [
    "lint"
  ],
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/github",
      [
        "@semantic-release/npm",
        {
          "npmPublish": true
        }
      ]
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@eslint/js": "^9.39.2",
    "@rollup/plugin-typescript": "^11.1.6",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/npm": "^13.1.1",
    "@types/node": "^25.0.9",
    "@types/prismjs": "^1.26.5",
    "@types/set-cookie-parser": "^2.4.10",
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.4.23",
    "cypress": "^15.10.0",
    "eslint": "^9.39.2",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-vue": "^9.33.0",
    "express": "^4.22.1",
    "generate-changelog": "^1.8.0",
    "husky": "^8.0.3",
    "postcss": "^8.5.6",
    "semantic-release": "^25.0.2",
    "standard-version": "^9.5.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^6.4.1"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "peerDependencies": {
    "cypress": ">=15.10.0"
  },
  "dependencies": {
    "prismjs": "^1.30.0",
    "set-cookie-parser": "^3.0.1",
    "vue": "^3.5.27"
  },
  "overrides": {
    "undici": ">=6.23.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/filiphric/cypress-plugin-api.git"
  },
  "bugs": {
    "url": "https://github.com/filiphric/cypress-plugin-api/issues"
  },
  "homepage": "https://github.com/filiphric/cypress-plugin-api#readme"
}
